const BOLD_ACRO=/\b(LPDI|EPC-HHPLC|IDMRP|FLTC|ICDRA|MABNC|IPS|MVO|VaR|CaR|KS-PME|LN-PME|PME|TPA|SAA|TAA|CPPI|OBPI|SWFs?|CTAs?|REITs?|NPI|NAREIT|NOI|LDI|ABO|PBO|DB|DC|GP|LP|CIO|COO|CFO|CRO|SEC|NIS|MLM|GSCI|AUM|IRR)\b/g;
