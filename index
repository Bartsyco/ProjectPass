function occupied(c,r){
  return NPCS.some(n=>n.map===state.map&&n.c===c&&n.r===r)
      || OBJECTS.some(o=>o.map===state.map&&o.c===c&&o.r===r);
}
function walkable(c,r){
  if(c<0||r<0||c>=cols()||r>=rows()) return false;
  if(SOLID.has(grid()[r][c])) return false;
  if(occupied(c,r)) return false;
  return true;
}
function showBang(c,r,cb){
  const b=document.createElement('div'); b.className='bang'; b.textContent='❗';
  b.style.left=c*TILE+'px'; b.style.top=(r-1)*TILE+'px';
  stage.appendChild(b);
  setTimeout(()=>{ b.remove(); cb&&cb(); },650);
}
function checkTrainers(){
  for(const t of NPCS.filter(n=>n.trainer&&n.map===state.map)){
    if(state.defeated[t.id]) continue;
    if((state.trainerCd[t.id]||0)>0) continue;
    if(Math.abs(t.c-state.px)+Math.abs(t.r-state.py)<=2){
      state.mode='wait';
      showBang(t.c,t.r,()=>{
        const gv=t.quizVillage||village();
        if(!quizGate(gv, t.name)){ state.trainerCd[t.id]=8; return; }
        startQuiz(t.name, t.quizVillage);
        const idx=state.quizIdx, v=state.quizVillage;
        const w=setInterval(()=>{
          if(state.mode!=='quiz'){ clearInterval(w);
            if(state.answered[v].has(idx)) state.defeated[t.id]=true;
            else state.trainerCd[t.id]=8;
          }
        },300);
      });
      return true;
    }
  }
  return false;
}
function switchMap(to,x,y){
  state.map=to; state.px=x; state.py=y;
  renderMap(); updateHud();
  drawGuide();
}
function step(dir){
  if(state.mode!=='walk') return;
  let nx=state.px, ny=state.py;
  if(dir==='up')ny--; else if(dir==='down')ny++; else if(dir==='left')nx--; else if(dir==='right')nx++;
  if(!walkable(nx,ny)) return;

  const ch=grid()[ny][nx];
  const door=curMap().doors[nx+','+ny];
  if(door){
    if(door.req && state.tokens<door.req && !recoveryDoorPass(door)){
      openDialog(door.gate,[door.msg,`Your balance: ${state.tokens} α. The trainers and tall grass 🌿 of all three villages await.`]);
      return;
    }
    switchMap(door.to, door.x, door.y);
    return;
  }
  if(ch==='S'){
    const ex=curMap().exit;
    switchMap(HOME[village()], ex.x, ex.y);
    return;
  }
  state.px=nx; state.py=ny;
  placePlayer(); camera(false);
  drawGuide();
  if(state.map==='world'){
    const vNow=village();
    if(vNow!==state.lastVillage){
      state.lastVillage=vNow;
      maybeOfferTour(vNow);
      if(state.mode!=='walk') return;
    }
  }
  document.getElementById('zoneName').textContent=currentZoneName();
  saveProgress(); updateDesktopPanel();
  Object.keys(state.trainerCd).forEach(k=>{ if(state.trainerCd[k]>0) state.trainerCd[k]--; });
  if(state.grassCd>0) state.grassCd--;
  if(checkTrainers()) return;
  if(ch==='F' && state.grassCd===0 && Math.random()<0.25){
    state.grassCd=6; state.mode='wait';
    const badged=['v1','v4','v2','v3'].filter(bv=>state.answered[bv].size>=BADGE_REQ[bv]);
    const here=village();
    let qv=here, foeName='Wild MCQ';
    const others=badged.filter(bv=>bv!==here);
    if(badged.length>=2 && others.length && Math.random()<0.35){
      qv=others[Math.floor(Math.random()*others.length)];
      foeName='⛈️ Storm — Wild MCQ from '+VILLAGE_NAME[qv];
    }
    showBang(nx,ny,()=>{ if(quizGate(qv,foeName)) startQuiz(foeName,qv); });
  }
}
function adjacentEntity(){
  const dirs=[[0,-1],[0,1],[-1,0],[1,0]];
  for(const [dc,dr] of dirs){
    const c=state.px+dc, r=state.py+dr;
    const n=NPCS.find(n=>n.map===state.map&&n.c===c&&n.r===r);
    if(n) return {kind:'npc', e:n};
    const o=OBJECTS.find(o=>o.map===state.map&&o.c===c&&o.r===r);
    if(o) return {kind:'obj', e:o};
  }
  return null;
}
function markSeen(e){
  if(!e.los) return;
  e.los.forEach(x=>state.seenLOs[village()].add(x));
  armBounties(e.los);
  saveProgress(); updateDesktopPanel();
}
let lastArmed=[];
function armBounties(los){
  lastArmed=[];
  ['v1','v4','v2','v3'].forEach(v=>{
    state.bounty[v].forEach(idx=>{
      if(state.bountyArmed[v].has(idx)) return;
      const Q=BANKS[v][idx]; if(!Q) return;
      const hit=los.some(x=>x.indexOf(Q.lo)===0&&(x.length===Q.lo.length||/[a-z]/.test(x.charAt(Q.lo.length))));
      if(hit){
        state.bountyArmed[v].add(idx); lastArmed.push('LO '+Q.lo);
        if(state.guideQ && state.guideQ.v===v && state.guideQ.idx===idx) state.guideQ=null;
      }
    });
  });
  lastArmed=[...new Set(lastArmed)];
}
function armedLine(){
  if(!lastArmed.length) return null;
  const s='🎯 RECOVERY ARMED for '+lastArmed.join(', ')+' — the rematch now pays your '+BOUNTY+' α back. Go win it.';
  lastArmed=[];
  return s;
}
function readObject(o){
  if(o.board){ showTodo(); return; }
  markSeen(o);
  const extra=armedLine();
  openDialog(o.name, extra?[...o.lines, extra]:o.lines);
}
function talk(e){
  if(e.travel){ travellerTalk(e); return; }
  if(e.grandtour){ grandTalk(e); return; }
  if(e.boss){ bossTalk(e); return; }
  if(e.cr){ crTalk(e); return; }
  if(e.trainer){
    const gv=e.quizVillage||village();
    if(!quizGate(gv, e.name)) return;
    startQuiz(e.name+(state.defeated[e.id]?' (rematch)':''), e.quizVillage); return;
  }
  markSeen(e);
  const lines=e.lines();
  const extra=armedLine();
  openDialog(e.name, extra?[...lines, extra]:lines);
}
function interact(){
  if(state.mode==='todo'){ closeTodo(); return; }
  if(state.mode==='dialog'){ advanceDialog(); return; }
  if(state.mode!=='walk') return;
  const hit=adjacentEntity();
  if(!hit) return;
  if(hit.kind==='npc') talk(hit.e);
  else readObject(hit.e);
}

