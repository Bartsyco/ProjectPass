    missionCards.push('<div class="v26-card"><h3>2 · Spaced review</h3><p>'+(due?'A review is due in <b>'+V26_TOPIC[due.v].short+'</b>. Answer it before it becomes familiar-but-forgotten.':'No due review now. Fresh questions are okay.')+'</p><button class="v26-action" data-v26-action="due" '+(due?'':'disabled')+'>Start due drill</button></div>');
    missionCards.push('<div class="v26-card"><h3>3 · Weak-concept reclaim</h3><p>'+(weak?'Your error log still contains a testable weakness in <b>'+V26_TOPIC[weak.v].short+'</b>.':'No weak question available. Create useful data by fighting trainers.')+'</p><button class="v26-action" data-v26-action="weak" '+(weak?'':'disabled')+'>Reclaim weak concept</button></div>');
    missionCards.push('<div class="v26-card"><h3>4 · Coverage gap</h3><p>Lowest LO coverage: <b>'+V26_TOPIC[low.v].short+'</b> at '+pct(low.lo.seen,low.lo.total)+'%. Explore buildings and objects before more random battles.</p><button class="v26-action" data-v26-action="focus" data-v26-v="'+low.v+'">Show memory spine</button></div>');
    missionCards.push('<div class="v26-card"><h3>5 · Written answer muscle</h3><p>'+(crNeed?('Need <b>'+crNeed+'</b> more scored CR pass'+(crNeed>1?'es':'')+' for Ethics Epsilon. Use Word Forge/skeleton before writing.'):'CR badge threshold reached. Keep one written rep per session.')+'</p><button class="v26-action" data-v26-action="words">Open Word Forge</button></div>');
    missionCards.push('<div class="v26-card"><h3>Reward streak</h3><p>Current streak: <span class="v26-streak">'+state.v26.streak+'</span> · best: <span class="v26-streak">'+state.v26.bestStreak+'</span>. Bonus: +3 α every 3 correct, +8 α every 6 correct. Wrong resets it.</p><p>Total mission picture: due '+totals.due+' · weak '+totals.weak+' · locks '+totals.locked+'.</p></div>');
    body.innerHTML='<div class="v26-lead"><b>Next best action:</b> '+esc(v26MissionHeadline())+'<br>Good exam rhythm: rescue mistakes → due review → weak reclaim → coverage gap → written response.</div><div class="v26-mission">'+missionCards.join('')+'</div>';
  }
  function showMind(){ if(state.mode!=='walk') return; v26Ensure(); state.v26.active=village(); state.mode='v26mind'; renderMind(); document.getElementById('v26Mind').style.display='flex'; }
  function closeMind(){ document.getElementById('v26Mind').style.display='none'; if(state.mode==='v26mind') state.mode='walk'; }
  function showMission(){ if(state.mode!=='walk') return; v26Ensure(); state.mode='v26mission'; renderMission(); document.getElementById('v26Mission').style.display='flex'; }
  function closeMission(){ document.getElementById('v26Mission').style.display='none'; if(state.mode==='v26mission') state.mode='walk'; }
  function v26StartTarget(target,label){
    if(!target){ openDialog('🎯 Mission Coach',['No valid question found for that mission. Explore a new resident, open the Memory Palace, or fight a road rival to create retrieval data.']); return; }
    if(!quizGate(target.v,label||'Mission Coach')) return;
    startQuiz(label||'🎯 Mission Drill',target.v,target.idx);
  }
  function v26Action(act,v){
    if(act==='mission'){ closeMind(); showMission(); return; }
    if(act==='focus'){ closeMission(); state.v26.active=v||village(); showMind(); return; }
    if(act==='recovery'){
      const lock=v26FirstLocked(); closeMission();
      if(lock){ state.guideQ={v:lock.v, idx:lock.idx, until:Date.now()+60000}; drawGuide(); openDialog('🎯 Mission Coach',['Follow the 📍 trail to the teacher for LO '+BANKS[lock.v][lock.idx].lo+'. Read it with A, then the missed question returns first.']); }
      return;
    }
    if(act==='due'){ const t=v26FirstDue(); closeMission(); v26StartTarget(t,'⌛ Due Review'); return; }
    if(act==='weak'){ const t=v26FirstWeak(); closeMission(); v26StartTarget(t,'🎯 Weak-Concept Reclaim'); return; }
    if(act==='words'){ closeMission(); if(typeof showWords==='function') showWords(); return; }
    if(act==='export'){ v26ExportMap(); return; }
  }
  function v26ExportMap(){
    const lines=['CAIA World v26 Memory Map', 'Exported: '+new Date().toISOString(), 'Next action: '+v26MissionHeadline(), ''];
    V26_ORDER.forEach(v=>{ const t=V26_TOPIC[v], lo=v26LO(v); lines.push(t.n+' — '+t.land); lines.push('Route: '+t.route); lines.push('Spine: '+t.spine.join(' -> ')); lines.push('Status: '+v26Rank(v)+' | LO '+lo.seen+'/'+lo.total+' | MCQ '+state.answered[v].size+'/'+BANKS[v].length+' | due '+v26Due(v).length+' | weak '+v26Weak(v).length); lines.push('Why: '+t.why); lines.push(''); });
    const blob=new Blob([lines.join('\n')],{type:'text/plain;charset=utf-8'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='caia_world_v26_memory_map.txt'; document.body.appendChild(a); a.click(); setTimeout(()=>{URL.revokeObjectURL(a.href); a.remove();},500);
  }
  function renderSideCoach(){
    const el=document.getElementById('v26SideCoach'); if(!el) return;
    const totals=v26Totals();
    el.innerHTML='<h2>EXAM MISSION</h2><p>'+esc(v26MissionHeadline())+'</p><div class="v26-minirow"><span>Due</span><span>'+totals.due+'</span></div><div class="v26-minirow"><span>Weak</span><span>'+totals.weak+'</span></div><div class="v26-minirow"><span>Locks</span><span>'+totals.locked+'</span></div><div class="v26-minirow"><span>Streak</span><span>'+state.v26.streak+' / best '+state.v26.bestStreak+'</span></div><button class="v26-action" type="button" id="v26SideMissionBtn">Open mission board (J)</button><button class="v26-action secondary" type="button" id="v26SideMindBtn">Memory palace (P)</button>';
    document.getElementById('v26SideMissionBtn')?.addEventListener('click',()=>{ if(state.mode==='walk') showMission(); });
    document.getElementById('v26SideMindBtn')?.addEventListener('click',()=>{ if(state.mode==='walk') showMind(); });
  }
  const _save=saveProgress;
  saveProgress=function(){
    _save();
    try{ const raw=localStorage.getItem(SAVE_KEY); const data=raw?JSON.parse(raw):{}; data.v26=state.v26; localStorage.setItem(SAVE_KEY, JSON.stringify(data)); }catch(e){}
  };
  const _load=loadProgress;
  loadProgress=function(){
    _load(); v26Ensure();
    try{ const raw=localStorage.getItem(SAVE_KEY); if(raw){ const data=JSON.parse(raw); if(data.v26) state.v26=Object.assign(state.v26,data.v26); } }catch(e){}
    v26Ensure();
  };
  const _settle=settle;
  settle=function(good,timeout){
    _settle(good,timeout); v26Ensure();
    if(good && !timeout){
      state.v26.streak=(Number(state.v26.streak)||0)+1;
      state.v26.bestStreak=Math.max(Number(state.v26.bestStreak)||0,state.v26.streak);
      let bonus=0;
      if(state.v26.streak>0 && state.v26.streak%6===0) bonus=8;
      else if(state.v26.streak>0 && state.v26.streak%3===0) bonus=3;
      if(bonus){ state.tokens+=bonus; if(quizWhy && quizWhy.style.display==='block') quizWhy.innerHTML+='<div class="english-tip"><b>Streak reward:</b> '+state.v26.streak+' correct in a row → +'+bonus+' α. The reward is for consistent retrieval, not grinding.</div>'; }
    } else {
      state.v26.streak=0;
    }
    saveProgress(); updateHud(); renderCompass();
  };
  const _update=updateDesktopPanel;
  updateDesktopPanel=function(){
    _update(); v26Ensure();
    const totals=v26Totals();
    const bank=document.getElementById('sideBank'); if(bank) bank.textContent=totals.bank+' items · due '+totals.due+' · weak '+totals.weak;
    renderSideCoach(); renderCompass();
  };
  const _render=renderMap;
  renderMap=function(){ _render(); v26EnsureUI(); renderCompass(); };
  v26Ensure(); v26EnsureUI();
})();


/* ================================================================
   GO
   ================================================================ */
loadProgress();
renderMap(); updateHud();
if(!state.introSeen){
setTimeout(()=>{
  state.introSeen=true; saveProgress();
  openDialog('Prof. Kaia',[
   "Welcome to CAIA WORLD, Level II candidate. One road runs through the whole exam: ETHICS VILLAGE (Topic 1), ASSET OWNERS CITY (Topic 2), PORTFOLIO CONSTRUCTION VILLAGE (Topic 3), RISK & RISK MGMT VILLAGE (Topic 4). Walk it in curriculum order.",
   "Move with the arrows or the D-pad. Enter buildings by their door \uD83D\uDEAA and read any resident, object, or wall plaque with A. Each village has a \uD83D\uDCCB quest board (press Q or tap the zone name) tracking every learning objective, a hillside mnemonic sign, and a first-visit guided tour offered by its elder.",
   "Battles: MCQs and \uD83E\uDDE9 list battles (select-all or tap-in-order). Right answers earn \u03B1 (+5/+10/+15 by difficulty, timed at exam pace). Wrong answers cost \u221220 \u03B1 and become a \uD83C\uDFAF recovery bounty: a \uD83D\uDCCD trail points to the exact teacher, and a \uD83D\uDD12 study lock stops all questions until you re-read it \u2014 then the missed question returns first and refunds the \u03B1. Correct answers come back on an adaptive schedule (1\u21924\u21927\u219214\u219230\u219260 days).",
   "New in v21: every playable village now has a fragment-skeleton desk. Use it before a written answer: pick the thesis, three mechanisms, and implication, while ignoring decoy fragments. Each village has its own terrain colour, roof colour, and interior room label, so you know the topic by sight without cluttering the map.",
   "Badges: Epsilon \uD83C\uDFC5\u0395 (Ethics) is earned by WRITING \u2014 3 scored constructed-response answers at 70%+ at the \u270D\uFE0F CR Dojo, not by MCQs. Phi \uD83C\uDFC5\u03A6 (Owners, 14), Pi \uD83C\uDFC5\u03A0 (Portfolio, 18), Sigma \uD83C\uDFC5\u03C3 (Risk, 18) come from distinct correct battles. Each village also hides a boss gauntlet (\u2b50) and the \uD83E\uDDF1 Word Forge (press L) gives English sentence stems for written answers.",
   "\u26A0 The daily ration halves rewards after 12 questions: this game is your retrieval-and-recovery layer, not your main study \u2014 keep your RemNote reviews and written practice as the engine. The \uD83D\uDDFA\uFE0F World Atlas (press M) holds all 10 topics and 1,162 objectives. And in Ethics Village you\u2019ll find \uD83D\uDC69\u200D\uD83D\uDE80 Aria the Pathfinder, who fast-travels you between villages for 10 \u03B1 a hop \u2014 once your recovery routes are clear \u2014 and \uD83D\uDC69\u200D\uD83C\uDFEB Professor Vista, who gives a free continental GRAND TOUR of all four villages and every house. Off you go."
  ]);
},400);
}
</script>
