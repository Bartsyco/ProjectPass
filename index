function submitList(timeout){
  const L=state.quizList; if(!L || quizGo.style.display==='block') return;
  clearInterval(quizTimerIv);
  const goods=L.items.filter(x=>x.good);
  let good;
  if(L.lt==='order'){
    good = L.picked.length===goods.length && L.picked.every((x,i)=>x.good && x.ord===i);
  } else {
    good = L.picked.length===goods.length && L.picked.every(x=>x.good);
  }
  [...quizOpts.children].forEach(b=>{
    b.disabled=true;
    if(b._it.good){ b.classList.add('good'); b.textContent=(L.lt==='order'?(b._it.ord+1)+'. ':'')+b._it.t; }
    if(L.picked.includes(b._it) && !b._it.good) b.classList.add('bad');
  });
  quizSubmit.style.display='none';
  settle(good, timeout);
}
function answer(txt,btn){
  if(quizGo.style.display==='block') return;
  if(state.quizList){ submitList(txt===null); return; }
  clearInterval(quizTimerIv);
  const timeout = txt===null;
  const good = !timeout && txt===state.quizAnswer;
  [...quizOpts.children].forEach(b=>{
    b.disabled=true;
    if(b.textContent.slice(3)===state.quizAnswer) b.classList.add('good');
  });
