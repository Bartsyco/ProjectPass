/* ================================================================
   ONE WORLD OVERWORLD: exterior villages are stitched into one map.
   Order: Ethics (T1) -> Asset Owners (T2) -> Portfolio Construction (T3) -> Risk (T4).
   Exterior village transitions use a walkable road only; building doors still work.
   ================================================================ */
const ONE_WORLD_ORDER = ['world3','world2','world4','world1'];
const ONE_WORLD_VILLAGE = {world1:'v1', world2:'v2', world3:'v3', world4:'v4'};
const ONE_WORLD_CONNECTOR = 8;
const ONE_WORLD_OFFSETS = {};
function stitchExteriorToOneWorld(){
  let cursor = 0;
  ONE_WORLD_ORDER.forEach((id, idx)=>{
    ONE_WORLD_OFFSETS[id] = cursor;
    cursor += MAPS[id].grid[0].length;
    if(idx < ONE_WORLD_ORDER.length - 1) cursor += ONE_WORLD_CONNECTOR;
  });
  const totalRows = MAPS[ONE_WORLD_ORDER[0]].grid.length;
  const connectorRows = Array.from({length:totalRows}, (_,r)=>{
    if(r===0 || r===totalRows-1) return 'T'.repeat(ONE_WORLD_CONNECTOR);
    if(r===6) return 'P'.repeat(ONE_WORLD_CONNECTOR);
    if(r===5 || r===7) return 'GGFFGGGG';
    if(r===8 || r===12) return 'GGGFFGGG';
    return 'G'.repeat(ONE_WORLD_CONNECTOR);
  });
  const bigGrid = [];
  for(let r=0;r<totalRows;r++){
    let row = '';
    ONE_WORLD_ORDER.forEach((id, idx)=>{
      let part = MAPS[id].grid[r].replace(/Z/g,'P');
      if(r===6) part = 'P' + part.slice(1, -1) + 'P';
      row += part;
      if(idx < ONE_WORLD_ORDER.length - 1) row += connectorRows[r];
    });
    bigGrid.push(row);
  }
  const bigLabels = [
    {t:'ETHICS VILLAGE - TOPIC 1', c:2, r:0},
    {t:'ASSET OWNERS CITY - TOPIC 2', c:ONE_WORLD_OFFSETS.world2+2, r:0},
    {t:'PORTFOLIO CONSTRUCTION - TOPIC 3', c:ONE_WORLD_OFFSETS.world4+2, r:0},
    {t:'RISK & RISK MGMT - TOPIC 4', c:ONE_WORLD_OFFSETS.world1+2, r:0},
    {t:'Road link: fiduciary duty -> IPS', c:ONE_WORLD_OFFSETS.world3+25, r:5},
    {t:'Road link: IPS -> allocation engine', c:ONE_WORLD_OFFSETS.world2+25, r:5},
    {t:'Road link: allocation -> risk control', c:ONE_WORLD_OFFSETS.world4+25, r:5}
  ];
  ONE_WORLD_ORDER.forEach(id=>{
    const off = ONE_WORLD_OFFSETS[id];
    MAPS[id].labels.forEach(L=>{
      if(String(L.t).includes('←') || String(L.t).includes('→')) return;
      bigLabels.push({t:L.t, c:L.c+off, r:L.r});
    });
  });
  const bigSigns = [];
  ONE_WORLD_ORDER.forEach(id=>{
    const off = ONE_WORLD_OFFSETS[id];
    (MAPS[id].signs||[]).forEach(S=>bigSigns.push({word:S.word, c:S.c+off, r:S.r}));
  });
  const exterior = new Set(ONE_WORLD_ORDER);
  const bigDoors = {};
  ONE_WORLD_ORDER.forEach(id=>{
    const off = ONE_WORLD_OFFSETS[id];
    Object.entries(MAPS[id].doors).forEach(([key,d])=>{
      if(exterior.has(d.to)) return;
      const [c,r] = key.split(',').map(Number);
      bigDoors[(c+off)+','+r] = Object.assign({}, d);
      if(MAPS[d.to] && MAPS[d.to].exit){
        MAPS[d.to].exit = {x: MAPS[d.to].exit.x + off, y: MAPS[d.to].exit.y};
      }
    });
  });
  MAPS.world = {
    name:'🗺 CAIA WORLD - ONE CONTINUOUS ROAD',
    grid:bigGrid,
    labels:bigLabels,
    signs:bigSigns,
    doors:bigDoors
  };
}
stitchExteriorToOneWorld();

