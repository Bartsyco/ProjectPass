  // drop at the village's entrance on the road: column = offset + entrance, a walkable road tile
  const g=MAPS.world.grid;
  let ex=off+6, ey=11;
  // find nearest walkable tile around the intended entrance
  const walk=(c,r)=>g[r]&&!SOLID.has(g[r][c])&&g[r][c]!=='S';
  if(!walk(ex,ey)){
    outer:
    for(let rad=1;rad<8;rad++)for(let dr=-rad;dr<=rad;dr++)for(let dc=-rad;dc<=rad;dc++){
      if(walk(off+6+dc, 11+dr)){ ex=off+6+dc; ey=11+dr; break outer; }
    }
  }
  travelEl.style.display='none';
  state.mode='walk';
  state.map='world'; state.px=ex; state.py=ey;
  state.lastVillage=v;
  renderMap(); updateHud(); saveProgress();
