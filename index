function startTour(v){
  const off=ONE_WORLD_OFFSETS[TOURS[v].map];
  const stops=TOURS[v].stops.map(s=>({c:s.c+off, r:s.r, text:s.text}));
  state.tour={v:v, stops:stops, i:0, gc:state.px, gr:state.py};
