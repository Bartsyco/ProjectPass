<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>CAIA World — L2 v26 (memory mission)</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
  :root{
    --grass:#79c059; --grass2:#71b951; --tallgrass:#4e9a3e;
    --path:#e6d197; --path2:#d8c384;
    --tree:#245628; --water:#4a90d9;
    --wallA:#f0e3c0; --roofA:#d4af37; --roofA2:#b8922a;
    --wallD:#e8d8c8; --roofD:#8e3b3b; --roofD2:#6f2c2c;
    --rock:#5b5566; --rock2:#494357; --pyr:#c9a227; --pyr2:#a8841c;
    --wood:#c89b6a; --wood2:#b8895a; --wall-in:#7a5a3a;
    --rug:#b23a48; --stone:#8a8494; --gold-in:#e3c463;
    --ink:#1c1c24; --paper:#f8f6ec;
    --hud:#16213e; --hud-edge:#0d1330;
    --ok:#2e8b57; --ko:#b23a48; --gold:#ffd23f;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%;}
  body{
    background:#0d1330;
    font-family:'Press Start 2P', monospace;
    color:var(--paper);
    display:flex; flex-direction:column;
    height:100dvh; overflow:hidden;
    -webkit-tap-highlight-color:transparent;
    touch-action:manipulation;
    user-select:none;
  }
  #hud{
    flex:0 0 auto;
    background:var(--hud); border-bottom:4px solid var(--hud-edge);
    padding:8px 10px;
    display:flex; justify-content:space-between; align-items:center; gap:8px;
    font-size:8px; line-height:1.7;
  }
  #hud .zone{color:var(--gold); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
  #hud .stats{white-space:nowrap;}
  #hud .stats span{margin-left:9px;}
  #tokens{color:var(--gold);}
  .bdg{display:none; color:var(--gold);}

  #viewport{flex:1 1 auto; position:relative; overflow:hidden; background:#183a1d; width:100%;}
  #stage{position:absolute; left:0; top:0; transition:transform .13s linear; will-change:transform;}
  #tiles{display:grid; line-height:0;}
  .t{width:44px; height:44px; position:relative;}
  .t.G{background:var(--grass);} .t.G.alt{background:var(--grass2);}
  .t.P{background:var(--path); box-shadow:inset 0 0 0 1px var(--path2);}
  .t.T{background:var(--tree);}
  .t.T::after{content:"🌳"; position:absolute; inset:0; font-size:32px; line-height:44px; text-align:center;}
  .t.F{background:var(--tallgrass);}
  .t.F::after{content:"🌿"; position:absolute; inset:0; font-size:24px; line-height:44px; text-align:center; opacity:.85;}
  .t.W{background:var(--water); animation:wob 2.4s infinite;}
  @keyframes wob{0%,100%{filter:brightness(1)}50%{filter:brightness(1.12)}}
  .t.R{background:linear-gradient(180deg,var(--roofA),var(--roofA2)); box-shadow:inset 0 -3px 0 rgba(0,0,0,.25);}
  .t.H{background:var(--wallA); box-shadow:inset 0 0 0 2px #cbb98c;}
  .t.H::after{content:""; position:absolute; left:11px; top:11px; width:22px; height:16px;
    background:#8fc4e8; border:3px solid #7a5a3a; border-radius:2px;}
  .t.r{background:linear-gradient(180deg,var(--roofD),var(--roofD2)); box-shadow:inset 0 -3px 0 rgba(0,0,0,.3);}
  .t.h{background:var(--wallD); box-shadow:inset 0 0 0 2px #b99f88;}
  .t.h::after{content:""; position:absolute; left:11px; top:11px; width:22px; height:16px;
    background:#2b2b3a; border:3px solid #5a3a2a; border-radius:2px;}
  .t.C{background:var(--rock); box-shadow:inset 0 0 0 3px var(--rock2);}
  .t.Y{background:var(--pyr); box-shadow:inset 0 0 0 2px var(--pyr2), inset 0 -4px 0 rgba(0,0,0,.15);}
  .t.O,.t.c,.t.y{background:#6b4a2a;}
  .t.O::after,.t.c::after,.t.y::after{content:"🚪"; position:absolute; inset:0; font-size:28px; line-height:44px; text-align:center;}
  .t.Z{background:var(--path);}
  .t.Z::after{content:"⛩️"; position:absolute; inset:0; font-size:30px; line-height:44px; text-align:center;}
  .t.X{background:var(--wall-in); box-shadow:inset 0 0 0 3px #5e4229;}
  .t.w{background:var(--wood); box-shadow:inset 0 -2px 0 var(--wood2);}
  .t.M{background:var(--rug); box-shadow:inset 0 0 0 2px #8e2e3a;}
  .t.U{background:var(--wood);}
  .t.U::after{content:"🗄️"; position:absolute; inset:0; font-size:28px; line-height:44px; text-align:center;}
  .t.B{background:var(--wood);}
  .t.B::after{content:"📦"; position:absolute; inset:0; font-size:28px; line-height:44px; text-align:center;}
  .t.K{background:var(--rock2); box-shadow:inset 0 0 0 3px #38334a;}
  .t.k{background:var(--stone);}
  .t.Q{background:var(--pyr2); box-shadow:inset 0 0 0 3px #8a6c12;}
  .t.q{background:var(--gold-in); box-shadow:inset 0 -2px 0 #c9a940;}
  .t.S{background:#6b4a2a;}
  .t.S::after{content:"⬇️"; position:absolute; inset:0; font-size:24px; line-height:44px; text-align:center;}

  .lbl{
    position:absolute; z-index:5; pointer-events:none;
    font-size:8px; color:#fff; text-shadow:1px 1px 0 #000;
    background:rgba(20,20,30,.72); padding:3px 5px; border-radius:3px;
    white-space:nowrap;
  }
  .lbl.lock{color:var(--gold);}
  .sprite{
    position:absolute; z-index:8; width:44px; height:44px;
    font-size:32px; line-height:44px; text-align:center;
    transition:left .13s linear, top .13s linear;
  }
  .sprite.obj{font-size:28px;}
  .sprite .tag{
    position:absolute; left:50%; transform:translateX(-50%); bottom:-9px;
    font-size:6px; color:#fff; text-shadow:1px 1px 0 #000; white-space:nowrap;
  }
  #playerSprite{z-index:10;}
  .bang{
    position:absolute; z-index:20; width:44px; text-align:center;
    font-size:22px; color:var(--gold); text-shadow:1px 1px 0 #000;
    animation:pop .18s ease-out;
  }
  @keyframes pop{from{transform:translateY(6px) scale(.4); opacity:0} to{transform:none; opacity:1}}

  #dialog{
    display:none; position:absolute; left:8px; right:8px; bottom:8px; z-index:30;
    background:var(--paper); color:var(--ink);
    border:4px solid var(--ink); border-radius:8px;
    padding:12px 14px; font-size:9px; line-height:1.9; min-height:84px;
    cursor:pointer;
  }
  #dialog .who{color:#7a2e8f; margin-bottom:5px; font-size:8px;}
  #dialog .next{position:absolute; right:10px; bottom:6px; animation:bob 1s infinite;}
  #dText{white-space:normal;}
  #dText p,#quizWhy p{margin:0 0 8px 0;}
  #dText p:last-child,#quizWhy p:last-child{margin-bottom:0;}
  #dText ul,#quizWhy ul{margin:6px 0 8px 15px; padding-left:11px;}
  #dText li,#quizWhy li{margin:4px 0; line-height:1.75;}
  #dText .lead,#quizWhy .lead{margin-bottom:7px;}
  #dText .formula,#quizWhy .formula{display:block; margin:6px 0; padding:5px 7px; background:#fff8dd; border-left:3px solid #b8942b;}
  @keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(3px)}}

  #quiz{
    display:none; position:fixed; inset:0; z-index:50;
    background:rgba(10,12,28,.85);
    align-items:center; justify-content:center; padding:10px;
  }
  #quizBox{
    width:100%; max-width:520px; max-height:92dvh; overflow-y:auto;
    background:var(--paper); color:var(--ink);
    border:4px solid var(--ink); border-radius:8px; padding:14px;
  }
  #quizBox .hdr{font-size:7px; color:#555; border-bottom:2px dashed #bbb; padding-bottom:7px; margin-bottom:9px; line-height:1.8;}
  #quizBox .foe{font-size:9px; color:#7a2e8f; margin-bottom:8px;}
  #quizBox .reward{font-size:7px; color:#8a6c12; margin-bottom:8px;}
  #quizBox .q{font-size:10px; line-height:1.8; margin-bottom:12px;}
  .opt{
    display:block; width:100%; text-align:left;
    font-family:inherit; font-size:9px; line-height:1.7;
    background:#fff; color:var(--ink);
    border:3px solid var(--ink); border-radius:6px;
    padding:10px; margin-bottom:8px; cursor:pointer;
  }
  .opt.good{background:#d7f2df; border-color:var(--ok);}
  .opt.bad{background:#f6dadd; border-color:var(--ko);}
  #quizWhy{display:none; font-size:8px; line-height:1.9; background:#eee7cf; border:2px solid #c9bd97; border-radius:6px; padding:9px; margin-top:4px;}
  #quizGo{display:none; width:100%; margin-top:10px; font-family:inherit; font-size:9px; padding:12px; background:var(--hud); color:#fff; border:3px solid #000; border-radius:6px; cursor:pointer;}

  #todo{
    display:none; position:fixed; inset:0; z-index:60;
    background:rgba(10,12,28,.88);
    align-items:center; justify-content:center; padding:10px;
  }
  #todoBox{
    width:100%; max-width:540px; max-height:92dvh; overflow-y:auto;
    background:var(--paper); color:var(--ink);
    border:4px solid var(--ink); border-radius:8px; padding:14px;
  }
  #todoTitle{font-size:10px; color:#7a2e8f; margin-bottom:10px; line-height:1.6;}
  .todo-part{
    font-size:8px; color:#fff; background:var(--hud);
    padding:6px 8px; border-radius:5px; margin:10px 0 6px;
  }
  .todo-lesson{font-size:7px; color:#7a2e8f; margin:7px 0 2px; padding-left:2px;}
  .todo-item{font-size:8px; line-height:1.9; padding:4px 2px; border-bottom:1px dashed #d8d0b8;}
  .todo-item.done{color:#2e6b45;}
  .todo-item.na{color:#999;}
  .todo-item .note{font-size:7px; color:#aaa;}
  .todo-foot{font-size:8px; color:#8a6c12; margin-top:10px; line-height:1.8;}
  #todoClose{
    width:100%; margin-top:10px; font-family:inherit; font-size:9px; padding:12px;
    background:var(--hud); color:#fff; border:3px solid #000; border-radius:6px; cursor:pointer;
  }

  #controls{
    flex:0 0 auto;
    display:flex; align-items:center; justify-content:space-between;
    padding:10px 16px calc(12px + env(safe-area-inset-bottom));
    background:var(--hud-edge);
  }
  .dpad{display:grid; grid-template-columns:repeat(3,56px); grid-template-rows:repeat(3,56px); gap:3px;}
  .dbtn{
    background:var(--hud); border:3px solid #26335c; border-radius:10px;
    color:#fff; font-family:inherit; font-size:16px; cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    touch-action:none;
  }
  .dbtn:active{background:#2a3a6e;}
  .abtn{
    width:76px; height:76px; border-radius:50%;
    background:#7a2e8f; border:4px solid #571f66; color:#fff;
    font-family:inherit; font-size:15px; cursor:pointer;
  }
  .abtn:active{background:#933bab;}
  @media (min-width:760px){
    #controls{max-width:520px; margin:0 auto; width:100%; background:transparent;}
  }


  /* ==============================================================
     DESKTOP COMPUTER BUILD OVERRIDES
     - Wider play area
     - Touch controls hidden on desktop
     - Right study/control panel
     - Mobile layout preserved below 760px
     ============================================================== */
  body{
    background:
      radial-gradient(circle at 20% 0%, rgba(255,210,63,.13), transparent 28%),
      radial-gradient(circle at 80% 12%, rgba(122,46,143,.22), transparent 30%),
      #0d1330;
  }
  #hud{
    min-height:52px;
    padding:10px 16px;
    box-shadow:0 4px 0 rgba(0,0,0,.22);
  }
  #gameShell{
    flex:1 1 auto;
    min-height:0;
    width:100%;
    max-width:1480px;
    margin:0 auto;
    padding:14px;
    display:grid;
    grid-template-columns:minmax(620px,1fr) 310px;
    gap:14px;
  }
  #viewport{
    flex:unset;
    min-width:0;
    min-height:0;
    height:100%;
    border:4px solid #0b1029;
    border-radius:12px;
    box-shadow:0 10px 28px rgba(0,0,0,.36), inset 0 0 0 2px rgba(255,255,255,.06);
  }
  #desktopPanel{
    min-height:0;
    overflow:auto;
    background:rgba(22,33,62,.94);
    border:4px solid #0b1029;
    border-radius:12px;
    padding:12px;
    box-shadow:0 10px 28px rgba(0,0,0,.28);
  }
  .panel-card{
    background:rgba(13,19,48,.78);
    border:2px solid #26335c;
    border-radius:8px;
    padding:10px;
    margin-bottom:10px;
    font-size:7px;
    line-height:1.9;
  }
  .panel-card h2{
    font-size:8px;
    color:var(--gold);
    margin-bottom:7px;
    line-height:1.6;
  }
  .panel-card p{margin:0 0 6px;}
  .panel-card ul{padding-left:14px; margin:0;}
  .panel-card li{margin-bottom:5px;}
  .key{
    display:inline-block;
    min-width:26px;
    text-align:center;
    background:var(--paper);
    color:var(--ink);
    border:2px solid #000;
    border-radius:4px;
    padding:1px 4px;
    margin:0 2px 2px 0;
    box-shadow:0 2px 0 #000;
  }
  .panel-stat{
    display:flex;
    justify-content:space-between;
    gap:8px;
    border-bottom:1px dashed rgba(255,255,255,.18);
    padding:4px 0;
  }
  .panel-stat span:last-child{
    color:var(--gold);
    text-align:right;
  }
  .panel-btn{
    width:100%;
    font-family:inherit;
    font-size:7px;
    line-height:1.7;
    padding:9px;
    color:#fff;
    background:#7a2e8f;
    border:3px solid #571f66;
    border-radius:7px;
    cursor:pointer;
  }
  .panel-btn:hover{filter:brightness(1.08);}
  #controls{display:none;}
  @media (min-width:1100px){
    #quizBox{max-width:720px;}
    #todoBox{max-width:860px;}
    #dialog{left:18px; right:18px; bottom:18px; max-width:980px; margin:0 auto;}
  }
  @media (max-width:759px){
    body{background:#0d1330;}
    #hud{min-height:auto; padding:8px 10px; box-shadow:none;}
    #gameShell{display:block; flex:1 1 auto; min-height:0; padding:0; margin:0; max-width:none;}
    #viewport{height:100%; border:0; border-radius:0; box-shadow:none;}
    #desktopPanel{display:none;}
    #controls{
      flex:0 0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:10px 16px calc(12px + env(safe-area-inset-bottom));
      background:var(--hud-edge);
    }
  }


  /* ===== WORLD ATLAS (v11) ===== */
  #btnAtlas{background:none; border:0; font-size:14px; cursor:pointer; padding:0 2px; line-height:1;}
  #atlas{display:none; position:fixed; inset:0; z-index:70; background:rgba(10,12,28,.92);
    align-items:center; justify-content:center; padding:10px;}
  #atlasBox{width:100%; max-width:620px; height:94dvh; display:flex; flex-direction:column;
    background:var(--paper); color:var(--ink); border:4px solid var(--ink); border-radius:8px; padding:12px;}
  #atlasTop{display:flex; align-items:center; gap:8px; margin-bottom:8px;}
  #atlasTitle{font-size:9px; color:#7a2e8f; line-height:1.6; flex:1;}
  #atlasBackBtn{display:none; font-family:inherit; font-size:8px; padding:8px; background:var(--hud);
    color:#fff; border:2px solid #000; border-radius:6px; cursor:pointer;}
  #atlasBody{flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch;}
  .atl-head{font-size:7px; line-height:1.9; color:#555; background:#efe9d2; border:2px solid #d8d0b8;
    border-radius:6px; padding:8px; margin-bottom:8px;}
  .atl-card{display:flex; gap:10px; align-items:center; border:3px solid var(--ink); border-radius:8px;
    padding:10px; background:#fff; cursor:pointer;}
  .atl-card.frontier{background:#e9e9ef; border-color:#8a8494;}
  .atl-emoji{flex:0 0 44px; height:44px; display:flex; align-items:center; justify-content:center;
    font-size:24px; border-radius:8px; border:2px solid rgba(0,0,0,.3);}
  .atl-name{font-size:8px; line-height:1.6;}
  .atl-info{flex:1; min-width:0;}
  .atl-land{font-size:7px; color:#7a2e8f; margin:3px 0; line-height:1.7;}
  .atl-bar{height:8px; background:#ded6bd; border:1px solid #b8b096; border-radius:4px; overflow:hidden;}
  .atl-bar div{height:100%; background:var(--ok);}
  .atl-sub{font-size:6.5px; color:#666; margin-top:4px; line-height:1.8;}
  .atl-road{width:8px; height:18px; margin:0 auto;
    background:repeating-linear-gradient(180deg,var(--path2) 0 6px, transparent 6px 10px);}
  .atl-ch{border:2px solid #d8d0b8; border-radius:6px; margin-bottom:8px; overflow:hidden;}
  .atl-ch-hd{display:flex; gap:6px; align-items:center; font-size:7.5px; line-height:1.7; padding:8px;
    background:var(--hud); color:#fff; cursor:pointer;}
  .atl-ch-hd .cnt{margin-left:auto; color:var(--gold); white-space:nowrap; padding-left:6px;}
  .atl-ch-body{padding:6px 8px; background:#fffef7;}
  .atl-les{font-size:7.5px; line-height:1.8; padding:6px 2px 2px; cursor:pointer; border-top:1px dashed #d8d0b8;}
  .atl-les.done{color:#2e6b45;}
  .atl-lo{font-size:7px; line-height:1.8; color:#555; padding:1px 0 1px 16px;}
  .atl-foot{font-size:7px; color:#8a6c12; margin-top:10px; line-height:1.9;}
  #atlasClose{width:100%; margin-top:8px; font-family:inherit; font-size:9px; padding:12px;
    background:var(--hud); color:#fff; border:3px solid #000; border-radius:6px; cursor:pointer;}

  /* ===== v13: exam clock + CR dojo ===== */
  #timerToggle{float:right; font-family:inherit; font-size:7px; padding:6px 8px; margin-left:6px;
    background:#26335c; color:#fff; border:2px solid #000; border-radius:6px; cursor:pointer;}
  #quizTimer,#crTimer{height:8px; background:#ded6bd; border:1px solid #b8b096; border-radius:4px;
    overflow:hidden; margin:6px 0;}
  #quizTimerFill,#crTimerFill{height:100%; width:100%; background:linear-gradient(90deg,#c0392b,#e67e22);
    transition:width .1s linear;}
  #cr{display:none; position:fixed; inset:0; z-index:65; background:rgba(10,12,28,.92);
    align-items:center; justify-content:center; padding:10px;}
  #crBox{width:100%; max-width:620px; max-height:94dvh; overflow-y:auto; -webkit-overflow-scrolling:touch;
    background:var(--paper); color:var(--ink); border:4px solid var(--ink); border-radius:8px; padding:12px;}
  #crPrompt{font-size:8.5px; line-height:1.8; color:#7a2e8f; margin:8px 0;}
  .cr-slot{font-size:7px; line-height:1.8; border:2px dashed #b8b096; border-radius:6px; padding:7px;
    margin-bottom:6px; color:#999; background:#f6f1de;}
  .cr-slot.filled{border-style:solid; border-color:var(--ink); color:var(--ink); background:#fff; cursor:pointer;}
  .cr-lab{color:#8a6c12; display:block; margin-bottom:3px;}
  .cr-frag{display:block; width:100%; text-align:left; font-family:inherit; font-size:7px; line-height:1.8;
    padding:7px; margin-bottom:6px; background:#26335c; color:#fff; border:2px solid #000; border-radius:6px; cursor:pointer;}
  #crResult{display:none; font-size:7px; line-height:1.9; background:#efe9d2; border:2px solid #d8d0b8;
    border-radius:6px; padding:8px; margin:8px 0;}
  #crSubmit,#crClose{width:100%; margin-top:6px; font-family:inherit; font-size:9px; padding:12px;
    background:var(--hud); color:#fff; border:3px solid #000; border-radius:6px; cursor:pointer;}
  /* ===== v14: Hollywood mnemonic signs ===== */
  .hsign{background:none !important; border:0 !important; padding:0 !important;
    display:flex; align-items:flex-end; justify-content:center;
    color:#fff; font-weight:bold; letter-spacing:0;
    text-shadow:2px 2px 0 #2b2b2b, -2px 2px 0 #2b2b2b, 2px -2px 0 #2b2b2b, -2px -2px 0 #2b2b2b, 0 6px 5px rgba(0,0,0,.45);
    transform:skewY(-4deg); z-index:3; pointer-events:none;}
  /* ===== v15: guide trail + tours ===== */
  .gdot{position:absolute; width:9px; height:9px; background:#ffd23e; border:2px solid #7a5a00;
    border-radius:50%; z-index:4; pointer-events:none; animation:gpulse 1s infinite;}
  .gtarget{position:absolute; font-size:22px; z-index:5; pointer-events:none; animation:gbounce .8s infinite;}
  @keyframes gpulse{0%,100%{transform:scale(.6);opacity:.45}50%{transform:scale(1.15);opacity:1}}
  @keyframes gbounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
  #tourAsk{display:none; position:fixed; inset:0; z-index:75; background:rgba(10,12,28,.85);
    align-items:center; justify-content:center; padding:12px;}
  #tourAskBox{width:100%; max-width:480px; background:var(--paper); color:var(--ink);
    border:4px solid var(--ink); border-radius:8px; padding:14px;}
  #tourAskText{font-size:8.5px; line-height:1.9; margin-bottom:10px;}
  #tourAskBtns{display:flex; gap:8px;}
  #tourAskBtns button{flex:1; font-family:inherit; font-size:8px; padding:12px 6px;
