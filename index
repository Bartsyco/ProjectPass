function guideTarget(){
  const gq=state.guideQ; if(!gq) return null;
  if(Date.now()>gq.until){ state.guideQ=null; return null; }
  const Q=BANKS[gq.v] && BANKS[gq.v][gq.idx]; if(!Q) return null;
  if(!state.bounty[gq.v].has(gq.idx)){ state.guideQ=null; return null; }
  const ts=teachersFor(Q.lo); if(!ts.length) return null;
  const best=ts.find(t=>t.map===state.map) || ts.find(t=>t.map==='world') || ts[0];
  if(best.map===state.map) return {c:best.c, r:best.r};
  if(state.map==='world'){ return worldDoorTo(best.map); }
  const g=grid();
  for(let r=0;r<g.length;r++){ const c=g[r].indexOf('S'); if(c>=0) return {c:c, r:r}; }
  return null;
}
function drawGuide(){
  [...stage.querySelectorAll('.gdot,.gtarget')].forEach(e=>e.remove());
  const t=guideTarget(); if(!t) return;
  const x0=state.px, y0=state.py, dx=t.c-x0, dy=t.r-y0;
  const n=Math.max(Math.abs(dx),Math.abs(dy));
  if(n<=1){ return; }
  const steps=Math.min(n,40);
  for(let i=1;i<steps;i++){
    const cx=x0+dx*(i/steps), cy=y0+dy*(i/steps);
    const e=document.createElement('div'); e.className='gdot';
    e.style.left=(cx*TILE+TILE*0.32)+'px'; e.style.top=(cy*TILE+TILE*0.32)+'px';
    e.style.animationDelay=(i*0.07)+'s';
    stage.appendChild(e);
  }
  const m=document.createElement('div'); m.className='gtarget'; m.textContent='📍';
  m.style.left=(t.c*TILE)+'px'; m.style.top=((t.r-0.9)*TILE)+'px';
  stage.appendChild(m);
}
