  settle(good, timeout);
}
function settle(good, timeout){
  state.tot++;
  const v=state.quizVillage, idx=state.quizIdx;
  const Q=BANKS[v][idx];
  const today=new Date().toISOString().slice(0,10);
  if(state.daily.d!==today){ state.daily.d=today; state.daily.n=0; }
  state.daily.n++;
  if(good){
    state.ok++;
    let base=REWARD[state.quizD], note='';
    if(state.daily.n>RATION_FREE){ base=Math.ceil(base/2); note+=' (ration: reward halved)'; }
    let gain=base, locked='';
    if(state.bounty[v].has(idx)){
      if(state.bountyArmed[v].has(idx)){
        gain+=BOUNTY; note+=' + 🎯 '+BOUNTY+' α recovered';
        state.bounty[v].delete(idx); state.bountyArmed[v].delete(idx);
      } else {
        locked=formatStudyText(`🎯 ${BOUNTY} α still LOCKED — right answer, but you never re-read the teacher.\n\n${recoveryHint(Q)}`);
      }
    }
    state.tokens+=gain;
    state.answered[v].add(idx); state.answeredAt[v][idx]=Date.now();
    quizWhy.innerHTML=formatStudyText(`✅ +${gain} α${note} — ${state.quizWhy}`)+locked;
  }else{
    state.tokens=Math.max(0,state.tokens-PENALTY);
    state.bounty[v].add(idx); state.bountyArmed[v].delete(idx);
    state.missLog[v].add(idx);
    state.answered[v].delete(idx); delete state.answeredAt[v][idx];
    state.pendingGuide={v:v, idx:idx};
    quizWhy.innerHTML=formatStudyText((timeout?`⏱ TIME UP — counted as wrong. `:'')+`❌ −${PENALTY} α — ${state.quizWhy}\n\n${recoveryHint(Q)}`);
  }
  if(state.boss){
    if(!good) state.boss.lives--;
    quizGo.textContent=(state.boss.lives<=0 || state.boss.i+1>=state.boss.qs.length)?'Finish ⚑':'Next ▶';
  } else quizGo.textContent='Continue ▶';
  quizWhy.style.display='block'; quizGo.style.display='block';
  updateHud();
}
quizGo.addEventListener('click',()=>{
