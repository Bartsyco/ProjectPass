function studyOrders(v){
  return unarmedIdx(v).slice(0,4).map(i=>{
    const Q=BANKS[v][i];
    const ts=teachersFor(Q.lo);
    if(!ts.length) return '**LO '+Q.lo+'** → quest board (Q)';
    const best=ts.find(t=>t.map==='world')||ts[0];
    const where=best.map==='world'?'':' in '+(MAPS[best.map]?MAPS[best.map].name:best.map);
    return '**LO '+Q.lo+'** → '+(best.emoji?best.emoji+' ':'')+best.name+where;
  }).join('  ·  ');
}
