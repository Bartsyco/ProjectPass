function autoPlaceInVillage(exteriorId, prefC, prefR){
  const off=ONE_WORLD_OFFSETS[exteriorId];
  const g=MAPS.world.grid;
  const width=MAPS[exteriorId].grid[0].length;
  const occ=(c,r)=>NPCS.some(n=>n.map==='world'&&n.c===c&&n.r===r)||OBJECTS.some(o=>o.map==='world'&&o.c===c&&o.r===r);
  const isDoorTile=(c,r)=>MAPS.world.doors&&MAPS.world.doors[c+','+r];
  for(let rad=0; rad<16; rad++){
    for(let dr=-rad; dr<=rad; dr++)for(let dc=-rad; dc<=rad; dc++){
      if(Math.max(Math.abs(dc),Math.abs(dr))!==rad) continue;
      const lc=prefC+dc, lr=prefR+dr;
      if(lc<1||lr<1||lc>=width-1||lr>=g.length-1) continue;
      const c=off+lc, r=lr;
      if(!g[r]||g[r][c]!=='G') continue;
      if(occ(c,r)||isDoorTile(c,r)) continue;
      return {c,r};
    }
  }
  return null;
}
function autoPlaceInterior(mapId, prefC, prefR){
