function positionTourGuide(){
  if(!tourGuideEl||!state.tour) return;
  tourGuideEl.style.left=state.tour.gc*TILE+'px';
  tourGuideEl.style.top=state.tour.gr*TILE+'px';
}
function tourTick(){
  const t=state.tour; if(!t){ clearInterval(tourIv); return; }
  if(state.mode!=='tour') return;
  if(t.i>=t.stops.length){ endTour(false); return; }
  const s=t.stops[t.i];
  if(t.gc===s.c && t.gr===s.r){
    if(s.text){
      const who=t.grand?(GRAND_GUIDE+' '+GRAND_NAME):(TOURS[t.v].guide+' '+TOURS[t.v].name);
      openDialog(who, [s.text]);
    } else t.i++;
    return;
  }
  const dc=Math.sign(s.c-t.gc), dr=Math.sign(s.r-t.gr);
  const tryH=Math.abs(s.c-t.gc)>=Math.abs(s.r-t.gr);
  const opts=tryH?[[dc,0],[0,dr]]:[[0,dr],[dc,0]];
  let nc=t.gc, nr=t.gr, moved=false;
  for(const o of opts){
    if(o[0]===0&&o[1]===0) continue;
    if(walkable(t.gc+o[0], t.gr+o[1])){ nc=t.gc+o[0]; nr=t.gr+o[1]; moved=true; break; }
  }
  if(!moved){ nc=s.c; nr=s.r; }  /* safety teleport */
  const pc=t.gc, pr=t.gr;
  t.gc=nc; t.gr=nr;
  state.px=pc; state.py=pr;
  positionTourGuide(); placePlayer(); camera(false);
}
function endTour(skipped){
  const t=state.tour; if(!t) return;
  clearInterval(tourIv); tourIv=null;
  const isGrand=!!t.grand;
  if(!isGrand) state.tourDone[t.v]='done'; else state.tourDone.grand='done';
  state.tour=null; state.mode='walk';
  if(tourGuideEl){ tourGuideEl.remove(); tourGuideEl=null; }
  saveProgress(); renderMap();
  const gname=isGrand?(GRAND_GUIDE+' '+GRAND_NAME):(TOURS[t.v].guide+' '+TOURS[t.v].name);
  if(skipped) openDialog(gname, [isGrand
    ? 'Grand tour ended early. Talk to me again any time to restart \u2014 or to Aria for a quick paid hop.'
    : 'Tour skipped. The buildings all show their **chapter** in parentheses — read the signs as you go.']);
}

