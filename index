function boldify(s){
  return String(s)
    .replace(/\*\*(.+?)\*\*/g,'<b>$1</b>')
    .replace(BOLD_ACRO,'<b>$1</b>')
    .replace(BOLD_WORDS,'<b>$1</b>');
}
function lineToHtml(line){
  return boldify(String(line).trim());
}
function formatStudyText(raw){
  const text=String(raw||'').replace(/<br\s*\/?>(\s*)/gi,'\n\n').replace(/\r\n/g,'\n').trim();
  if(!text) return '';
  return text.split(/\n{2,}/).map(formatBlock).join('');
}
function formatBlock(block){
  let b=String(block).trim();
  if(!b) return '';

  const explicit=b.split(/\n+/).map(x=>x.trim()).filter(Boolean);
  if(explicit.length>1){
    let lead=[];
    let bullets=[];
    explicit.forEach(line=>{
      const m=line.match(/^(?:[-•*○]|\d+[.)])\s*(.+)$/);
      if(m) bullets.push(m[1]); else lead.push(line);
    });
    if(bullets.length>=2 || (lead.length && bullets.length)){
      return (lead.length?'<p class="lead">'+lineToHtml(lead.join(' '))+'</p>':'')+
        '<ul>'+bullets.map(x=>'<li>'+lineToHtml(x)+'</li>').join('')+'</ul>';
    }
  }

  if((b.match(/\s·\s/g)||[]).length>=1){
    const parts=b.split(/\s·\s/).map(x=>x.trim()).filter(Boolean);
    if(parts.length>=2){
      let lead='';
      let first=parts[0];
      const cut=first.lastIndexOf(':');
      if(cut>=0 && first.slice(cut+1).trim().length>0 && first.slice(0,cut).length<220){
        lead=first.slice(0,cut+1).trim();
        first=first.slice(cut+1).trim();
      }
      const items=[first].concat(parts.slice(1));
      return (lead?'<p class="lead">'+lineToHtml(lead)+'</p>':'')+
        '<ul>'+items.map(x=>'<li>'+lineToHtml(x)+'</li>').join('')+'</ul>';
    }
  }

  if(/^[-+]?\d+(?:\.\d+)?\s*[=≈]/.test(b) || /(?:^|\s)(?:=|≈)\s*[-+]?\d/.test(b)){
    return '<p><span class="formula">'+lineToHtml(b)+'</span></p>';
  }
  return '<p>'+lineToHtml(b)+'</p>';
}
