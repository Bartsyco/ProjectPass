function doorRecordTo(mapId){
  const doors=(MAPS.world&&MAPS.world.doors)||{};
  for(const k in doors){
    const d=doors[k];
    if(d.to===mapId){ const a=k.split(',').map(Number); return {c:a[0], r:a[1], door:d}; }
  }
  return null;
}
function teacherNormallyReachable(t){
  if(!t) return false;
  if(t.map==='world') return true;
  if(t.map===state.map) return true;
  const rec=doorRecordTo(t.map);
  if(!rec || !rec.door.req) return true;
  return state.tokens>=rec.door.req;
}
function questionHasReachableTeacher(Q){
  const ts=teachersFor(Q.lo);
  if(!ts.length) return true;
  return ts.some(teacherNormallyReachable);
}
function questionBlockedByLockedRecovery(v,i){
  const Q=BANKS[v]&&BANKS[v][i];
  if(!Q) return false;
  return !questionHasReachableTeacher(Q);
}
function recoveryDoorPass(door){
  if(!door || !door.req || state.tokens>=door.req) return true;
  const targetMap=door.to;
  for(const v of ['v1','v4','v2','v3']){
    const owed=state.bounty[v] ? [...state.bounty[v]] : [];
    for(const idx of owed){
      if(state.bountyArmed[v] && state.bountyArmed[v].has(idx)) continue;
      const Q=BANKS[v]&&BANKS[v][idx]; if(!Q) continue;
      const ts=teachersFor(Q.lo);
      const targetInside=ts.some(t=>t.map===targetMap);
      const reachableElsewhere=ts.some(t=>t.map!==targetMap && teacherNormallyReachable(t));
      if(targetInside && !reachableElsewhere) return true;
    }
  }
  return false;
}
function lockedRecoveryLabel(mapId){
  const rec=doorRecordTo(mapId);
  if(!rec || !rec.door.req || state.tokens>=rec.door.req) return '';
  return ' 🔐 normally gated, but a recovery pass will open it because this is your missed concept.';
}
